# AutoCAD MCP Pro — Environment Variables

# Backend selection: auto | com | ezdxf
AUTOCAD_MCP_BACKEND=auto

# Comma-separated list of allowed directories for file operations.
# Leave empty to allow all paths (not recommended for production).
# Example: ALLOWED_PATHS=C:\Drawings,D:\Projects\CAD
ALLOWED_PATHS=

# Maximum undo stack size (number of snapshots to keep)
MAX_UNDO_STACK=50

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Enable dangerous AutoCAD commands (ERASE ALL, QUIT, etc.)
# Set to true only if you trust all MCP clients
DANGEROUS_COMMANDS_ENABLED=false
